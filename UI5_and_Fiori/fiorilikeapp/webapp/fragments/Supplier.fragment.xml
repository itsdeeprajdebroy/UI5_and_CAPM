<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m">
    <Table id="idTable" items="{/suppliers}" mode="SingleSelectMaster" itemPress="onPressNext">
        <headerToolbar>
            <Toolbar>
                <ToolbarSpacer />
                <Button icon="sap-icon://filter" press="onFilter"></Button>
            </Toolbar>
        </headerToolbar>
        <columns>
            <Column >
                <Label text="Name" />
            </Column>
            <Column >
                <Label text="City" />
            </Column>
            <Column >
                <Label text="Contact" />
            </Column>
            <Column >
                <Label text="Since When" />
            </Column>
        </columns>
        <items>
            <ColumnListItem type="Navigation">
                <cells>
                    <Text text="{name}"/>
                    <Input value="{city}" showValueHelp="true" valueHelpRequest="onPressValueHelp"/>
                    <Text text="{contactName}"/>
                    <Text text="{sinceWhen}"/>
                </cells>
            </ColumnListItem>
        </items>
    </Table>
</core:FragmentDefinition>