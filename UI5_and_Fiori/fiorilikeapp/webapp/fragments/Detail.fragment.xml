<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:f="sap.ui.layout.form">
    <f:SimpleForm editable="true">
        <f:content>
            <Label text="Name"></Label>
            <Text text="{name}"></Text>
            <Label text="Taste"></Label>
            <Text text="{type}"></Text>
            <Label text="Price"></Label>
            <Text text="{price}"></Text>
            <Label text="Availability"></Label>
            <Text text="{path: 'status',
                        formatter: '.formatter.getStatus'}"></Text>
            <Label text=""></Label>
            <Button text="Hey Press Me" press="onPress"/>
        </f:content>
    </f:SimpleForm>
</core:FragmentDefinition>